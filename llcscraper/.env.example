# CT LLC Scraper Configuration
# Copy to .env and fill in your values: cp .env.example .env

# Proton Mail Bridge SMTP
SMTP_EMAIL=you@protonmail.com
SMTP_PASSWORD=your-bridge-password
SMTP_SERVER=127.0.0.1
SMTP_PORT=1025
SMTP_SECURITY=starttls

# Email settings
EMAIL_FROM_NAME=Jesse
SITE_URL=https://hammerandpixels.com

# API key for remote dashboard access (localhost is always allowed)
LLCSCRAPER_API_KEY=

# Flask
FLASK_DEBUG=false
